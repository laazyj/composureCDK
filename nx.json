{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build", "build"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build", "typecheck"],
      "outputs": ["{projectRoot}/coverage"],
      "cache": true
    },
    "check:exports": {
      "dependsOn": ["build"],
      "inputs": ["{projectRoot}/dist/**/*", "{projectRoot}/package.json"],
      "cache": true
    },
    "test:update": {
      "dependsOn": ["^build", "typecheck"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  },
  "release": {
    "projectsRelationship": "fixed",
    "projects": ["packages/*"],
    "version": {
      "conventionalCommits": true,
      "fallbackCurrentVersionResolver": "disk",
      "preVersionCommand": "npm run verify",
      "git": {
        "commit": false,
        "tag": false,
        "push": false
      }
    },
    "changelog": {
      "automaticFromRef": true,
      "projectChangelogs": false,
      "workspaceChangelog": {
        "renderer": "{workspaceRoot}/scripts/changelog-renderer.cjs"
      },
      "git": {
        "commit": false,
        "tag": false,
        "push": false
      }
    },
    "releaseTag": {
      "pattern": "v{version}"
    }
  },
  "analytics": false
}
