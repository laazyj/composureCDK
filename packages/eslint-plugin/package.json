{
  "name": "@composurecdk/eslint-plugin",
  "version": "0.9.0",
  "description": "Internal ESLint plugin encoding ComposureCDK architectural invariants (tagged builders, lifecycle context, builder copy state).",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/laazyj/composureCDK",
    "directory": "packages/eslint-plugin"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint .",
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "Jason Duffett (https://github.com/laazyj)",
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "devDependencies": {
    "@types/estree": "^1.0.6",
    "@types/node": "^25.9.3",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "nx": {
    "tags": [
      "scope:tooling"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc -p tsconfig.build.json",
          "cwd": "{projectRoot}"
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc --noEmit",
          "cwd": "{projectRoot}"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run",
          "cwd": "{projectRoot}"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "eslint .",
          "cwd": "{projectRoot}"
        }
      }
    }
  }
}
