{
  "name": "@composurecdk/examples",
  "version": "0.1.0",
  "description": "Example applications exercising the ComposureCDK public API",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist cdk.out",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:update": "vitest run --update",
    "test:watch": "vitest",
    "cdk": "cdk",
    "deploy": "cdk deploy",
    "synth": "cdk synth"
  },
  "author": "Jason Duffett (https://github.com/laazyj)",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@composurecdk/apigateway": "0.1.0",
    "@composurecdk/cloudformation": "0.1.0",
    "@composurecdk/core": "0.1.0",
    "@composurecdk/lambda": "0.1.0",
    "aws-cdk-lib": "^2.243.0",
    "constructs": "^10.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "aws-cdk": "^2.243.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
